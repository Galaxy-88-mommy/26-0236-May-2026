<script>
// ── DATA ──────────────────────────────────────────────────────────────────────
const PRODUCTS = [
  {id:1,title:"Vintage Denim Jacket",category:"Tops",size:"M",condition:"Good",price:850,img:"👕",color:"#E1F5EE",seller:"Amara K.",rating:4.8,desc:"Classic 90s denim jacket, slightly faded for that authentic vintage look. No tears or stains.",tags:["Vintage","Denim","Unisex"]},
  {id:2,title:"Nike Air Max 90",category:"Shoes",size:"42",condition:"Like New",price:2400,img:"👟",color:"#FAEEDA",seller:"Brian M.",rating:5.0,desc:"Worn twice only. Original box included. White/grey colourway. No scuffs.",tags:["Nike","Sneakers","Running"]},
  {id:3,title:"Leather Tote Bag",category:"Bags",size:"One size",condition:"Fair",price:600,img:"👜",color:"#FAECE7",seller:"Cynthia O.",rating:4.5,desc:"Genuine leather tote with a few light scratches. Interior is clean. Great everyday bag.",tags:["Leather","Tote","Work"]},
  {id:4,title:"HP EliteBook 840",category:"Electronics",size:"—",condition:"Good",price:28000,img:"💻",color:"#EEEDFE",seller:"David N.",rating:4.9,desc:"i5 8th gen, 8GB RAM, 256GB SSD. Battery holds 4 hrs. Charger included.",tags:["Laptop","HP","Work"]},
  {id:5,title:"Floral Midi Dress",category:"Dresses",size:"S",condition:"Like New",price:1200,img:"👗",color:"#FAECE7",seller:"Faith W.",rating:4.7,desc:"Worn once to a wedding. Dry cleaned. Vibrant floral print. Zipper works perfectly.",tags:["Dress","Floral","Summer"]},
  {id:6,title:"Levi's 501 Jeans",category:"Bottoms",size:"32x30",condition:"Good",price:1800,img:"👖",color:"#FAEEDA",seller:"George T.",rating:4.6,desc:"Classic straight fit. Minor fading at knees which adds character. No holes.",tags:["Levis","Denim","Classic"]},
  {id:7,title:"Wool Coat – Camel",category:"Outerwear",size:"L",condition:"Like New",price:3500,img:"🧥",color:"#E1F5EE",seller:"Hana J.",rating:5.0,desc:"100% wool blend. Barely worn. All buttons intact. Dry clean only.",tags:["Coat","Wool","Winter"]},
  {id:8,title:"Sony WH-1000XM3",category:"Electronics",size:"—",condition:"Good",price:8500,img:"🎧",color:"#EEEDFE",seller:"Isaac P.",rating:4.8,desc:"Noise cancelling headphones. Slight wear on ear cushions but function perfectly.",tags:["Sony","Audio","Noise Cancelling"]},
  {id:9,title:"Adidas Track Jacket",category:"Tops",size:"XL",condition:"Good",price:950,img:"🧢",color:"#E1F5EE",seller:"Janet L.",rating:4.4,desc:"Classic 3-stripe track jacket in navy/white. Zip works fine.",tags:["Adidas","Sportswear","Track"]},
  {id:10,title:"Rattan Side Table",category:"Home",size:"—",condition:"Good",price:2200,img:"🪑",color:"#FAEEDA",seller:"Kevin O.",rating:4.7,desc:"Boho rattan side table, 45cm tall. Minor scuff on leg. Great for bedroom.",tags:["Rattan","Furniture","Boho"]},
  {id:11,title:"Converse All Star Hi",category:"Shoes",size:"38",condition:"Fair",price:700,img:"👟",color:"#FAECE7",seller:"Lena M.",rating:4.3,desc:"Classic black hi-tops. Some sole yellowing and canvas marks. Still very wearable.",tags:["Converse","Casual","Classic"]},
  {id:12,title:"The Alchemist – Coelho",category:"Books",size:"—",condition:"Good",price:250,img:"📚",color:"#EEEDFE",seller:"Moses A.",rating:4.9,desc:"Paperback. No missing pages. Slight spine crease. Perfect reading copy.",tags:["Book","Fiction","Classic"]},
];
const CATEGORIES = ["All","Tops","Bottoms","Dresses","Shoes","Bags","Outerwear","Electronics","Home","Books"];
const CONDITIONS  = ["All","Like New","Good","Fair"];

// ── STATE ─────────────────────────────────────────────────────────────────────
let cart = [], wishlist = [], currentItem = null, detailQty = 1;
let selCat = "All", selCond = "All", maxPrice = 50000;
let loginMode = "login", sellStep = 1;
const SELL_STEPS = ["Photos","Details","Pricing","Review"];

// ── HELPERS ───────────────────────────────────────────────────────────────────
function fmt(n){ return "KSh " + Number(n).toLocaleString(); }

function updateCartBadge(){
  const b = document.getElementById("cartBadge");
  b.textContent = cart.length;
  b.style.display = cart.length ? "block" : "none";
}

function makeCard(p, context="shop"){
  const liked = wishlist.includes(p.id);
  return `
    <div class="card" onclick="openItem(${p.id})">
      <div class="card-img" style="background:${p.color}">
        ${p.img}<span class="card-badge">${p.condition}</span>
      </div>
      <div class="card-body">
        <div class="card-title">${p.title}</div>
        <div class="card-sub">${p.category} · Size ${p.size}</div>
        <div class="card-foot">
          <span class="card-price">${fmt(p.price)}</span>
          <div class="card-actions">
            <button class="btn-wish" onclick="event.stopPropagation();toggleWish(${p.id},this)">${liked?"❤️":"🤍"}</button>
            <button class="btn-add"  onclick="event.stopPropagation();addToCart(${p.id},this)">Add</button>
          </div>
        </div>
      </div>
    </div>`;
}

// ── PAGE ROUTING ──────────────────────────────────────────────────────────────
function showPage(name){
  document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
  document.getElementById("page-"+name).classList.add("active");
  document.querySelectorAll(".nav-links a").forEach(a=>a.classList.remove("active"));
  const nl = document.getElementById("nav-"+name);
  if(nl) nl.classList.add("active");
  if(name==="home") renderFeatured();
  if(name==="shop") renderShop();
  if(name==="cart") renderCart();
  if(name==="sell") renderSell();
  window.scrollTo(0,0);
}

// ── HOME ──────────────────────────────────────────────────────────────────────
function renderFeatured(){
  document.getElementById("featured-grid").innerHTML = PRODUCTS.slice(0,4).map(p=>makeCard(p,"home")).join("");
}

// ── SHOP ──────────────────────────────────────────────────────────────────────
function initShopFilters(){
  document.getElementById("cat-filters").innerHTML = CATEGORIES.map(c=>`<div class="filter-item ${c===selCat?'active':''}" onclick="setCat('${c}')">${c}</div>`).join("");
  document.getElementById("cond-filters").innerHTML = CONDITIONS.map(c=>`<div class="filter-item ${c===selCond?'active':''}" onclick="setCond('${c}')">${c}</div>`).join("");
}
function setCat(c){ selCat=c; renderShop(); }
function setCond(c){ selCond=c; renderShop(); }
function updatePrice(){ maxPrice=+document.getElementById("price-range").value; document.getElementById("price-val").textContent=fmt(maxPrice); }

function renderShop(){
  initShopFilters();
  const q = (document.getElementById("search-input")||{}).value||"";
  const sort = (document.getElementById("sort-select")||{}).value||"newest";
  let items = PRODUCTS.filter(p=>
    (selCat==="All"||p.category===selCat)&&
    (selCond==="All"||p.condition===selCond)&&
    p.price<=maxPrice&&
    (q===""||p.title.toLowerCase().includes(q.toLowerCase())||p.category.toLowerCase().includes(q.toLowerCase()))
  );
  if(sort==="low") items.sort((a,b)=>a.price-b.price);
  if(sort==="high") items.sort((a,b)=>b.price-a.price);
  document.getElementById("shop-count").textContent = items.length+" items available";
  const grid = document.getElementById("shop-grid");
  const empty = document.getElementById("shop-empty");
  if(items.length===0){ grid.innerHTML=""; empty.style.display="block"; }
  else { empty.style.display="none"; grid.innerHTML=items.map(p=>makeCard(p)).join(""); }
}

// ── ITEM DETAIL ───────────────────────────────────────────────────────────────
function openItem(id){
  currentItem = PRODUCTS.find(p=>p.id===id);
  detailQty = 1;
  document.getElementById("qty-val").textContent = 1;
  const p = currentItem;
  document.getElementById("detail-img-main").style.background = p.color;
  document.getElementById("detail-img-main").style.fontSize = "120px";
  document.getElementById("detail-img-main").textContent = p.img;
  document.getElementById("detail-thumbs").innerHTML = [1,2,3].map((i)=>`<div class="thumb ${i===1?'active':''}" style="background:${p.color}">${p.img}</div>`).join("");
  document.getElementById("detail-tags").innerHTML = p.tags.map(t=>`<span class="tag">${t}</span>`).join("");
  document.getElementById("detail-title").textContent = p.title;
  document.getElementById("detail-price").textContent = fmt(p.price);
  document.getElementById("detail-meta").innerHTML = [["Category",p.category],["Size",p.size],["Condition",p.condition],["Seller",p.seller]].map(([k,v])=>`<div class="meta-cell"><div class="meta-key">${k}</div><div class="meta-val">${v}</div></div>`).join("");
  document.getElementById("detail-desc").textContent = p.desc;
  document.getElementById("detail-seller").textContent = p.seller;
  document.getElementById("detail-rating").textContent = `⭐ ${p.rating} · Verified seller`;
  const w = document.getElementById("btn-wish-detail");
  w.textContent = wishlist.includes(p.id) ? "❤️" : "🤍";
  w.className = "btn-wish-lg" + (wishlist.includes(p.id) ? " liked" : "");
  const related = PRODUCTS.filter(x=>x.category===p.category&&x.id!==p.id).slice(0,4);
  document.getElementById("related-grid").innerHTML = related.map(x=>makeCard(x)).join("");
  showPage("item");
}
function changeQty(d){ detailQty=Math.max(1,detailQty+d); document.getElementById("qty-val").textContent=detailQty; }
function addFromDetail(){
  for(let i=0;i<detailQty;i++) addToCartDirect(currentItem);
  const btn = document.getElementById("btn-cart-detail");
  btn.textContent="✓ Added!"; btn.classList.add("added");
  setTimeout(()=>{ btn.textContent="Add to cart"; btn.classList.remove("added"); },2000);
}
function toggleWishDetail(){
  const id=currentItem.id;
  if(wishlist.includes(id)) wishlist=wishlist.filter(x=>x!==id);
  else wishlist.push(id);
  const w=document.getElementById("btn-wish-detail");
  w.textContent=wishlist.includes(id)?"❤️":"🤍";
  w.className="btn-wish-lg"+(wishlist.includes(id)?" liked":"");
}

// ── CART ──────────────────────────────────────────────────────────────────────
function addToCartDirect(p){ cart.push({...p, cartId:Date.now()+Math.random()}); updateCartBadge(); }
function addToCart(id, btn){
  const p=PRODUCTS.find(x=>x.id===id);
  addToCartDirect(p);
  if(btn){ const t=btn.textContent; btn.textContent="✓"; setTimeout(()=>btn.textContent=t,1200); }
}
function toggleWish(id, btn){
  if(wishlist.includes(id)) wishlist=wishlist.filter(x=>x!==id);
  else wishlist.push(id);
  btn.textContent=wishlist.includes(id)?"❤️":"🤍";
}
function removeCartItem(cartId){ cart=cart.filter(i=>i.cartId!==cartId); updateCartBadge(); renderCart(); }

function renderCart(){
  const empty=document.getElementById("cart-empty");
  const content=document.getElementById("cart-content");
  if(cart.length===0){ empty.style.display="block"; content.style.display="none"; return; }
  empty.style.display="none"; content.style.display="grid";
  document.getElementById("cart-items-list").innerHTML = cart.map(item=>`
    <div class="cart-item">
      <div class="cart-item-img" style="background:${item.color}">${item.img}</div>
      <div style="flex:1">
        <div class="cart-item-title">${item.title}</div>
        <div class="cart-item-sub">${item.category} · ${item.condition}</div>
        <div class="cart-item-price">${fmt(item.price)}</div>
      </div>
      <button class="cart-item-remove" onclick="removeCartItem(${item.cartId})">✕</button>
    </div>`).join("");
  const total = cart.reduce((s,i)=>s+i.price,0);
  document.getElementById("subtotal-label").textContent=`Subtotal (${cart.length} item${cart.length>1?"s":""})`;
  document.getElementById("subtotal-val").textContent=fmt(total);
  document.getElementById("fee-val").textContent=fmt(Math.round(total*.05));
  document.getElementById("total-val").textContent=fmt(Math.round(total*1.05));
  document.getElementById("eco-text").innerHTML=`By shopping second-hand, you're saving approx. <strong>${(cart.length*2.3).toFixed(1)} kg</strong> of CO₂!`;
}

function placeOrder(){
  cart=[]; updateCartBadge();
  document.getElementById("cart-wrap")||0;
  document.querySelector(".cart-wrap").innerHTML=`
    <div class="success-wrap" style="margin:0 auto;">
      <div class="success-icon">🎉</div>
      <h1>Order placed!</h1>
      <p>Thank you for shopping sustainably! Your seller will be notified.</p>
      <div class="success-btns">
        <button class="btn-primary" onclick="location.reload()">Continue shopping</button>
      </div>
    </div>`;
}

// ── LOGIN ─────────────────────────────────────────────────────────────────────
function setLoginMode(m){
  loginMode=m;
  document.getElementById("btn-login-mode").className="toggle-btn"+(m==="login"?" active":"");
  document.getElementById("btn-signup-mode").className="toggle-btn"+(m==="signup"?" active":"");
  document.getElementById("signup-name").style.display=m==="signup"?"block":"none";
  document.getElementById("confirm-field").style.display=m==="signup"?"block":"none";
  document.getElementById("login-btn").textContent=m==="login"?"Log in":"Create account";
  document.getElementById("forgot-link").style.display=m==="login"?"block":"none";
  document.getElementById("login-footer").innerHTML=m==="login"
    ?`Don't have an account? <span onclick="setLoginMode('signup')">Sign up</span>`
    :`Already have an account? <span onclick="setLoginMode('login')">Log in</span>`;
}
function doLogin(){
  document.querySelector(".login-wrap").innerHTML=`
    <div class="success-wrap">
      <div class="success-icon">✅</div>
      <h1>${loginMode==="login"?"Welcome back!":"Account created!"}</h1>
      <p>You're now logged in to NanaShop.</p>
      <button class="btn-primary" onclick="showPage('home')">Go to home</button>
    </div>`;
}

// ── SELL ──────────────────────────────────────────────────────────────────────
let sellForm = {title:"",category:"",condition:"",size:"",price:"",desc:"",delivery:true,meetup:false};

function renderSell(){
  // stepper
  const s=document.getElementById("stepper");
  s.innerHTML = SELL_STEPS.map((label,i)=>{
    const n=i+1;
    const done=sellStep>n, cur=sellStep===n;
    let html=`<div class="step-circle ${done?"done":cur?"current":""}">${done?"✓":n}</div>`;
    html+=`<span class="step-label ${cur?"current":""}">${label}</span>`;
    if(i<SELL_STEPS.length-1) html+=`<div class="step-line ${done?"done":""}"></div>`;
    return html;
  }).join("");

  const c=document.getElementById("sell-step-content");
  const nb=document.getElementById("sell-next-btn");
  nb.textContent=sellStep<4?"Continue →":"🌱 Publish listing";

  if(sellStep===1) c.innerHTML=`
    <h2>Add photos</h2>
    <div class="upload-zone">
      <div class="icon">📸</div>
      <p style="font-weight:500;margin-bottom:6px;">Drag & drop photos here</p>
      <p style="font-size:13px;color:#aaa;margin-bottom:16px;">or click to upload · JPG, PNG · max 5 photos</p>
      <button style="background:#E1F5EE;color:#085041;border:none;border-radius:8px;padding:9px 20px;font-size:13px;font-weight:500;cursor:pointer;font-family:Poppins,sans-serif;">Choose files</button>
    </div>
    <div class="thumb-row">${["Front","Back","Detail","Label"].map(l=>`<div class="thumb-ph">+ ${l}</div>`).join("")}</div>
    <p style="font-size:12px;color:#aaa;margin-top:12px;">💡 Tip: Clear, well-lit photos sell 3× faster.</p>`;

  if(sellStep===2) c.innerHTML=`
    <h2>Item details</h2>
    <p style="font-size:13px;color:#888;margin-bottom:20px;">Be accurate — buyers rely on this.</p>
    <label class="field-label">Item title *</label>
    <input class="field-input" id="s-title" value="${sellForm.title}" oninput="sellForm.title=this.value" placeholder="e.g. Vintage Levi's 501 Jeans"/>
    <label class="field-label">Category *</label>
    <select class="field-input" id="s-cat" onchange="sellForm.category=this.value">
      <option value="">Select a category</option>
      ${CATEGORIES.filter(c=>c!=="All").map(c=>`<option ${sellForm.category===c?"selected":""}>${c}</option>`).join("")}
    </select>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
      <div>
        <label class="field-label">Condition *</label>
        <select class="field-input" onchange="sellForm.condition=this.value">
          <option value="">Select</option>
          ${["Like New","Good","Fair","Poor"].map(c=>`<option ${sellForm.condition===c?"selected":""}>${c}</option>`).join("")}
        </select>
      </div>
      <div>
        <label class="field-label">Size</label>
        <input class="field-input" value="${sellForm.size}" oninput="sellForm.size=this.value" placeholder="e.g. M, 42"/>
      </div>
    </div>
    <label class="field-label">Description</label>
    <textarea class="field-input" rows="4" oninput="sellForm.desc=this.value" placeholder="Describe the item..." style="resize:vertical;line-height:1.6;">${sellForm.desc}</textarea>`;

  if(sellStep===3) c.innerHTML=`
    <h2>Set your price</h2>
    <label class="field-label">Listing price (KSh) *</label>
    <div style="position:relative;">
      <span style="position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:14px;color:#888;">KSh</span>
      <input class="field-input" type="number" id="s-price" value="${sellForm.price}" oninput="sellForm.price=this.value;updateEarnings()" placeholder="0" style="padding-left:56px;"/>
    </div>
    <div class="earnings-box" id="earnings-box" style="${sellForm.price?'':'display:none'}">
      <div style="font-weight:600;color:#085041;margin-bottom:6px;">You'll receive:</div>
      <div class="earnings-row"><span>Listing price</span><span id="earn-list">KSh 0</span></div>
      <div class="earnings-row"><span>Platform fee (5%)</span><span id="earn-fee">− KSh 0</span></div>
      <div class="earnings-row total"><span>Your earnings</span><span id="earn-net">KSh 0</span></div>
    </div>
    <h3 style="font-size:15px;font-weight:600;margin-top:24px;margin-bottom:14px;">Delivery options</h3>
    <label class="option-label ${sellForm.delivery?'checked':''}" id="opt-delivery">
      <input type="checkbox" ${sellForm.delivery?"checked":""} onchange="sellForm.delivery=this.checked;this.closest('.option-label').classList.toggle('checked',this.checked)" style="width:16px;height:16px;accent-color:#1D9E75;"/>
      <span class="option-icon">🚚</span>
      <div><div class="option-title">Delivery</div><div class="option-desc">Courier delivers to buyer's address</div></div>
    </label>
    <label class="option-label ${sellForm.meetup?'checked':''}" id="opt-meetup">
      <input type="checkbox" ${sellForm.meetup?"checked":""} onchange="sellForm.meetup=this.checked;this.closest('.option-label').classList.toggle('checked',this.checked)" style="width:16px;height:16px;accent-color:#1D9E75;"/>
      <span class="option-icon">🤝</span>
      <div><div class="option-title">Local meetup</div><div class="option-desc">Meet the buyer in person — free & safe</div></div>
    </label>`;
  if(sellStep===3 && sellForm.price) updateEarnings();

  if(sellStep===4) c.innerHTML=`
    <h2>Review & publish</h2>
    <div class="review-preview">
      <div class="review-title">${sellForm.title||"Untitled item"}</div>
      <div class="review-sub">${sellForm.category} · ${sellForm.condition} · Size ${sellForm.size||"—"}</div>
      <div class="review-price">${fmt(sellForm.price||0)}</div>
      ${sellForm.desc?`<p style="font-size:13px;color:#555;line-height:1.6;margin-top:10px;">${sellForm.desc}</p>`:""}
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;">
      ${sellForm.delivery?`<span class="tag">🚚 Delivery</span>`:""}
      ${sellForm.meetup?`<span class="tag">🤝 Meetup</span>`:""}
    </div>
    <div class="warning-box">⚠️ By publishing you confirm this item is accurately described and you own it.</div>`;
}

function updateEarnings(){
  const p=+sellForm.price||0;
  const box=document.getElementById("earnings-box");
  if(!box) return;
  box.style.display=p?"block":"none";
  document.getElementById("earn-list").textContent=fmt(p);
  document.getElementById("earn-fee").textContent="− "+fmt(Math.round(p*.05));
  document.getElementById("earn-net").textContent=fmt(Math.round(p*.95));
}

function sellBack(){ sellStep>1?sellStep--:showPage("home"); renderSell(); }
function sellNext(){
  if(sellStep<4){ sellStep++; renderSell(); }
  else {
    document.querySelector(".sell-wrap").innerHTML=`
      <div class="success-wrap" style="margin:0 auto;">
        <div class="success-icon">🎊</div>
        <h1>Item listed!</h1>
        <p>Your <strong>${sellForm.title||"item"}</strong> is now live on NanaShop.</p>
        <p style="color:#1D9E75;">🌱 Thank you for keeping fashion circular!</p>
        <div class="success-btns">
          <button class="btn-primary" onclick="showPage('shop')">View shop</button>
          <button class="btn-outline" onclick="resetSell()">List another</button>
        </div>
      </div>`;
  }
}
function resetSell(){
  sellForm={title:"",category:"",condition:"",size:"",price:"",desc:"",delivery:true,meetup:false};
  sellStep=1;
  showPage("sell");
}

// ── INIT ──────────────────────────────────────────────────────────────────────
renderFeatured();
renderShop();
</script>
</body>
</html>
