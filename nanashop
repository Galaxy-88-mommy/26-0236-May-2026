<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>NanaShop – Pre-loved Fashion</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;1,600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --green: #1D9E75; --green-light: #E1F5EE; --green-dark: #085041;
      --coral: #D85A30; --coral-light: #FAECE7;
      --amber-light: #FAEEDA; --purple-light: #EEEDFE;
      --bg: #FAFAF8; --white: #fff; --border: #eee;
    }
    body { font-family: 'Poppins', sans-serif; background: var(--bg); color: #1a1a1a; }
    a { text-decoration: none; color: inherit; }

    /* NAV */
    nav { background: var(--white); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; padding: 0 24px; }
    .nav-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 62px; }
    .logo { cursor: pointer; font-family: 'Playfair Display', serif; font-size: 24px; }
    .logo span:first-child { color: var(--green-dark); }
    .logo span:last-child  { color: var(--green); font-style: italic; }
    .nav-links { display: flex; gap: 28px; font-size: 14px; }
    .nav-links a { color: #555; font-weight: 400; padding-bottom: 4px; border-bottom: 2px solid transparent; transition: all .2s; }
    .nav-links a.active, .nav-links a:hover { color: var(--green); border-bottom-color: var(--green); font-weight: 500; }
    .nav-actions { display: flex; align-items: center; gap: 14px; }
    .btn-sell { background: var(--green); color: #fff; padding: 7px 18px; border-radius: 99px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; font-family: 'Poppins', sans-serif; }
    .btn-sell:hover { background: var(--green-dark); }
    .cart-icon { position: relative; cursor: pointer; font-size: 20px; }
    .cart-badge { position: absolute; top: -6px; right: -8px; background: var(--coral); color: #fff; border-radius: 99px; font-size: 10px; padding: 1px 5px; font-weight: 600; display: none; }

    /* PAGES */
    .page { display: none; }
    .page.active { display: block; }

    /* HERO */
    .hero { background: linear-gradient(135deg, #E1F5EE 0%, #d0f0e4 100%); padding: 72px 24px; text-align: center; }
    .hero-badge { display: inline-block; background: var(--green); color: #fff; border-radius: 99px; padding: 5px 16px; font-size: 12px; font-weight: 500; margin-bottom: 20px; letter-spacing: 1px; }
    .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(34px,5vw,58px); line-height: 1.15; color: var(--green-dark); margin-bottom: 18px; }
    .hero p  { font-size: 15px; color: #0F6E56; margin-bottom: 32px; line-height: 1.8; max-width: 520px; margin-left: auto; margin-right: auto; }
    .hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary { background: var(--green); color: #fff; border: none; padding: 13px 32px; border-radius: 99px; font-size: 15px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; transition: background .2s; }
    .btn-primary:hover { background: var(--green-dark); }
    .btn-outline { background: transparent; color: var(--green-dark); border: 1.5px solid var(--green-dark); padding: 13px 32px; border-radius: 99px; font-size: 15px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s; }
    .btn-outline:hover { background: var(--green-dark); color: #fff; }
    .stats { display: flex; gap: 32px; justify-content: center; margin-top: 48px; flex-wrap: wrap; }
    .stat-num { font-family: 'Playfair Display', serif; font-size: 28px; color: var(--green-dark); }
    .stat-lbl { font-size: 12px; color: #0F6E56; margin-top: 2px; }

    /* SECTIONS */
    .section { max-width: 1100px; margin: 0 auto; padding: 48px 24px 0; }
    .section-title { font-family: 'Playfair Display', serif; font-size: 28px; margin-bottom: 20px; }
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .btn-link { background: none; border: none; color: var(--green); font-weight: 500; font-size: 14px; cursor: pointer; font-family: 'Poppins', sans-serif; }

    /* CATEGORIES */
    .cats { display: flex; gap: 10px; flex-wrap: wrap; }
    .cat-chip { background: var(--white); border: 1px solid #e8e8e8; border-radius: 12px; padding: 10px 18px; font-size: 13px; display: flex; align-items: center; gap: 6px; color: #444; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s; }
    .cat-chip:hover { border-color: var(--green); color: var(--green); }

    /* PRODUCT GRID */
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 16px; }
    .card { background: var(--white); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; cursor: pointer; transition: transform .15s, box-shadow .15s; }
    .card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .card-img { height: 150px; display: flex; align-items: center; justify-content: center; font-size: 56px; position: relative; }
    .card-badge { position: absolute; top: 10px; right: 10px; background: #fff; border-radius: 99px; padding: 3px 10px; font-size: 11px; color: #555; font-weight: 500; }
    .card-body { padding: 12px 14px 14px; }
    .card-title { font-size: 14px; font-weight: 600; margin-bottom: 3px; }
    .card-sub   { font-size: 12px; color: #888; margin-bottom: 10px; }
    .card-foot  { display: flex; align-items: center; justify-content: space-between; }
    .card-price { font-size: 16px; font-weight: 700; color: var(--green-dark); }
    .card-actions { display: flex; gap: 8px; }
    .btn-wish { background: none; border: none; font-size: 16px; padding: 4px; cursor: pointer; }
    .btn-add  { background: var(--green); color: #fff; border: none; border-radius: 8px; padding: 6px 12px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .btn-add:hover { background: var(--green-dark); }

    /* HOW IT WORKS */
    .how { background: var(--white); margin-top: 64px; padding: 64px 24px; }
    .how-inner { max-width: 1100px; margin: 0 auto; }
    .how h2 { font-family: 'Playfair Display', serif; font-size: 32px; text-align: center; margin-bottom: 40px; }
    .how-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; }
    .how-card { text-align: center; padding: 32px 24px; background: var(--bg); border-radius: 16px; }
    .how-icon { font-size: 36px; margin-bottom: 16px; }
    .how-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
    .how-card p  { font-size: 13px; color: #666; line-height: 1.6; }

    /* FOOTER */
    footer { background: var(--green-dark); color: #9FE1CB; padding: 40px 24px; text-align: center; font-size: 13px; }
    footer .footer-logo { font-family: 'Playfair Display', serif; font-size: 22px; color: #fff; margin-bottom: 8px; }

    /* SHOP PAGE */
    .shop-wrap { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }
    .shop-top { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .shop-top input, .shop-top select { padding: 10px 16px; border-radius: 10px; border: 1px solid #ddd; font-size: 14px; background: var(--white); font-family: 'Poppins', sans-serif; outline: none; }
    .shop-top input { flex: 1; min-width: 200px; }
    .shop-layout { display: flex; gap: 28px; }
    .sidebar { width: 200px; flex-shrink: 0; }
    .sidebar-box { background: var(--white); border: 1px solid var(--border); border-radius: 14px; padding: 20px; }
    .sidebar-title { font-size: 13px; font-weight: 600; margin-bottom: 14px; text-transform: uppercase; letter-spacing: 1px; color: #999; }
    .filter-item { padding: 6px 0; font-size: 14px; cursor: pointer; color: #444; transition: color .15s; }
    .filter-item:hover, .filter-item.active { color: var(--green); font-weight: 600; }
    .price-val { font-size: 13px; color: var(--green); font-weight: 600; margin-bottom: 8px; }
    input[type=range] { width: 100%; accent-color: var(--green); }
    .empty { text-align: center; padding: 80px 0; color: #aaa; }
    .empty .empty-icon { font-size: 48px; margin-bottom: 16px; }

    /* ITEM DETAIL */
    .detail-wrap { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }
    .btn-back { background: none; border: none; color: var(--green); font-size: 14px; font-weight: 500; margin-bottom: 24px; padding: 0; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
    .detail-main-img { border-radius: 20px; height: 380px; display: flex; align-items: center; justify-content: center; font-size: 120px; }
    .detail-thumbs { display: flex; gap: 10px; margin-top: 12px; }
    .thumb { flex: 1; border-radius: 12px; height: 80px; display: flex; align-items: center; justify-content: center; font-size: 32px; opacity: .7; border: 2px solid transparent; cursor: pointer; }
    .thumb.active { opacity: 1; border-color: var(--green); }
    .tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
    .tag { background: var(--green-light); color: var(--green-dark); padding: 3px 12px; border-radius: 99px; font-size: 12px; font-weight: 500; }
    .detail-title { font-family: 'Playfair Display', serif; font-size: 32px; margin-bottom: 8px; }
    .detail-price { font-size: 28px; font-weight: 700; color: var(--green-dark); margin-bottom: 16px; }
    .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    .meta-cell { background: #f7f7f5; border-radius: 10px; padding: 10px 14px; }
    .meta-key { font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 3px; }
    .meta-val { font-size: 14px; font-weight: 500; }
    .detail-desc { font-size: 14px; color: #555; line-height: 1.8; margin-bottom: 24px; }
    .qty-row { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; }
    .qty-ctrl { display: flex; align-items: center; gap: 10px; background: #f0f0ee; border-radius: 10px; padding: 6px 14px; }
    .qty-btn { background: none; border: none; font-size: 18px; color: #555; cursor: pointer; }
    .qty-val { font-weight: 600; min-width: 20px; text-align: center; }
    .btn-cart { flex: 1; background: var(--green); color: #fff; border: none; border-radius: 12px; padding: 13px 0; font-size: 15px; font-weight: 600; cursor: pointer; font-family: 'Poppins', sans-serif; transition: background .3s; }
    .btn-cart.added { background: #059669; }
    .btn-wish-lg { background: #f0f0ee; border: none; border-radius: 12px; padding: 13px 16px; font-size: 20px; cursor: pointer; }
    .btn-wish-lg.liked { background: var(--coral-light); }
    .seller-card { background: #f7f7f5; border-radius: 14px; padding: 16px 20px; display: flex; align-items: center; gap: 14px; }
    .seller-avatar { width: 44px; height: 44px; border-radius: 99px; background: var(--green-light); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .seller-name { font-weight: 600; font-size: 14px; }
    .seller-rating { font-size: 12px; color: #888; }
    .btn-msg { margin-left: auto; background: none; border: 1px solid var(--green); color: var(--green); border-radius: 8px; padding: 7px 16px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .related { margin-top: 64px; }
    .related h2 { font-family: 'Playfair Display', serif; font-size: 26px; margin-bottom: 20px; }

    /* CART */
    .cart-wrap { max-width: 900px; margin: 0 auto; padding: 32px 24px; }
    .cart-layout { display: grid; grid-template-columns: 1fr 320px; gap: 32px; }
    .cart-items { display: flex; flex-direction: column; gap: 12px; }
    .cart-item { background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 16px; display: flex; gap: 16px; align-items: center; }
    .cart-item-img { width: 72px; height: 72px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; flex-shrink: 0; }
    .cart-item-title { font-weight: 600; font-size: 15px; }
    .cart-item-sub   { font-size: 12px; color: #888; margin-top: 3px; }
    .cart-item-price { font-size: 15px; font-weight: 700; color: var(--green-dark); margin-top: 6px; }
    .cart-item-remove { background: none; border: none; font-size: 18px; color: #ccc; cursor: pointer; padding: 4px; }
    .summary-box { background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; position: sticky; top: 80px; }
    .summary-box h2 { font-size: 18px; font-weight: 600; margin-bottom: 20px; }
    .summary-row { display: flex; justify-content: space-between; font-size: 14px; color: #666; margin-bottom: 10px; }
    .summary-row.total { font-weight: 700; font-size: 18px; color: var(--green-dark); margin: 16px 0 24px; }
    .free { color: var(--green); }
    .divider { border: none; border-top: 1px solid var(--border); margin: 10px 0; }
    .btn-checkout { width: 100%; background: var(--green); color: #fff; border: none; border-radius: 12px; padding: 14px 0; font-size: 15px; font-weight: 600; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .btn-checkout:hover { background: var(--green-dark); }
    .btn-continue { width: 100%; background: none; border: 1px solid #ddd; border-radius: 12px; padding: 12px 0; font-size: 14px; margin-top: 10px; color: #555; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .eco-note { margin-top: 16px; background: var(--green-light); border-radius: 10px; padding: 10px 14px; font-size: 12px; color: var(--green-dark); display: flex; gap: 8px; }
    .empty-cart { text-align: center; padding: 80px 0; }
    .empty-cart .icon { font-size: 64px; margin-bottom: 20px; }

    /* LOGIN */
    .login-wrap { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 40px 24px; }
    .login-box { width: 100%; max-width: 420px; }
    .login-logo { text-align: center; margin-bottom: 32px; }
    .login-logo .l1 { font-family: 'Playfair Display', serif; font-size: 30px; color: var(--green-dark); }
    .login-logo .l2 { font-family: 'Playfair Display', serif; font-size: 30px; color: var(--green); font-style: italic; }
    .login-logo p { color: #888; font-size: 14px; margin-top: 6px; }
    .login-card { background: var(--white); border-radius: 20px; border: 1px solid var(--border); padding: 32px 36px; }
    .toggle-row { display: flex; background: #f0f0ee; border-radius: 12px; padding: 4px; margin-bottom: 28px; }
    .toggle-btn { flex: 1; padding: 9px 0; border-radius: 9px; border: none; font-size: 14px; font-weight: 500; background: none; color: #888; cursor: pointer; font-family: 'Poppins', sans-serif; transition: all .2s; }
    .toggle-btn.active { background: var(--white); color: var(--green-dark); box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .field-label { font-size: 13px; font-weight: 500; color: #555; display: block; margin-bottom: 6px; margin-top: 14px; }
    .field-input { width: 100%; padding: 12px 16px; border-radius: 10px; border: 1.5px solid #e0e0e0; font-size: 14px; background: var(--bg); font-family: 'Poppins', sans-serif; outline: none; margin-bottom: 2px; }
    .field-input:focus { border-color: var(--green); }
    .btn-login { width: 100%; background: var(--green); color: #fff; border: none; border-radius: 12px; padding: 14px 0; font-size: 15px; font-weight: 600; margin-top: 14px; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .btn-login:hover { background: var(--green-dark); }
    .forgot { text-align: center; margin-top: 14px; font-size: 13px; color: var(--green); cursor: pointer; }
    .or-row { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
    .or-line { flex: 1; height: 1px; background: #eee; }
    .or-text { font-size: 12px; color: #aaa; }
    .social-row { display: flex; gap: 10px; }
    .btn-social { flex: 1; border-radius: 10px; padding: 10px 0; font-size: 14px; font-weight: 500; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .login-footer { text-align: center; font-size: 13px; color: #aaa; margin-top: 20px; }
    .login-footer span { color: var(--green); cursor: pointer; font-weight: 500; }

    /* SELL */
    .sell-wrap { max-width: 680px; margin: 0 auto; padding: 32px 24px 80px; }
    .stepper { display: flex; align-items: center; margin-bottom: 36px; }
    .step-circle { width: 32px; height: 32px; border-radius: 99px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; flex-shrink: 0; transition: all .3s; background: #e8e8e8; color: #aaa; }
    .step-circle.done, .step-circle.current { background: var(--green); color: #fff; }
    .step-label { font-size: 12px; margin-left: 8px; color: #aaa; white-space: nowrap; }
    .step-label.current { color: var(--green-dark); font-weight: 600; }
    .step-line { flex: 1; height: 2px; background: #e8e8e8; margin: 0 12px; transition: background .3s; }
    .step-line.done { background: var(--green); }
    .sell-card { background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 32px 36px; }
    .sell-card h2 { font-size: 20px; font-weight: 600; margin-bottom: 20px; }
    .upload-zone { border: 2px dashed #ddd; border-radius: 14px; padding: 48px 24px; text-align: center; cursor: pointer; background: var(--bg); }
    .upload-zone .icon { font-size: 48px; margin-bottom: 12px; }
    .thumb-row { display: flex; gap: 10px; margin-top: 16px; }
    .thumb-ph { flex: 1; aspect-ratio: 1; background: #f0f0ee; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: #aaa; border: 2px dashed #ddd; }
    .sell-nav { display: flex; justify-content: space-between; margin-top: 20px; }
    .btn-back2 { background: none; border: 1px solid #ddd; border-radius: 12px; padding: 12px 24px; font-size: 14px; color: #555; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .btn-next { background: var(--green); color: #fff; border: none; border-radius: 12px; padding: 12px 28px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: 'Poppins', sans-serif; }
    .btn-next:hover { background: var(--green-dark); }
    .earnings-box { background: var(--green-light); border-radius: 12px; padding: 14px 18px; margin-top: 16px; font-size: 13px; }
    .earnings-row { display: flex; justify-content: space-between; color: #555; margin-bottom: 4px; }
    .earnings-row.total { font-weight: 700; color: var(--green-dark); border-top: 1px solid #9FE1CB; padding-top: 6px; margin-top: 4px; }
    .option-label { display: flex; align-items: center; gap: 14px; background: #f7f7f5; border: 1.5px solid #e8e8e8; border-radius: 12px; padding: 14px 18px; cursor: pointer; margin-bottom: 10px; transition: all .2s; }
    .option-label.checked { background: var(--green-light); border-color: var(--green); }
    .option-icon { font-size: 22px; }
    .option-title { font-weight: 500; font-size: 14px; }
    .option-desc  { font-size: 12px; color: #888; }
    .warning-box { background: var(--amber-light); border-radius: 12px; padding: 14px 18px; font-size: 13px; color: #633806; }
    .review-preview { background: #f7f7f5; border-radius: 14px; padding: 20px; margin-bottom: 20px; }
    .review-title { font-weight: 600; font-size: 16px; margin-bottom: 4px; }
    .review-sub   { font-size: 13px; color: #888; margin-bottom: 10px; }
    .review-price { font-size: 22px; font-weight: 700; color: var(--green-dark); }

    /* SUCCESS STATES */
    .success-wrap { max-width: 500px; margin: 80px auto; text-align: center; padding: 0 24px; }
    .success-icon { font-size: 72px; margin-bottom: 24px; }
    .success-wrap h1 { font-family: 'Playfair Display', serif; font-size: 32px; margin-bottom: 12px; }
    .success-wrap p  { color: #666; font-size: 15px; line-height: 1.7; margin-bottom: 16px; }
    .success-btns { display: flex; gap: 12px; justify-content: center; margin-top: 16px; }

    @media(max-width:700px) {
      .detail-grid, .cart-layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <div class="logo" onclick="showPage('home')">
      <span>Nana</span><span>Shop</span>
    </div>
    <div class="nav-links">
      <a href="#" id="nav-home" class="active" onclick="showPage('home');return false;">Home</a>
      <a href="#" id="nav-shop" onclick="showPage('shop');return false;">Shop</a>
    </div>
    <div class="nav-actions">
      <button class="btn-sell" onclick="showPage('sell')">+ Sell</button>
      <div class="cart-icon" onclick="showPage('cart')">🛒<span class="cart-badge" id="cartBadge">0</span></div>
      <span style="cursor:pointer;font-size:20px;" onclick="showPage('login')">👤</span>
    </div>
  </div>
</nav>

<!-- ══ HOME PAGE ══ -->
<div id="page-home" class="page active">
  <div class="hero">
    <div class="hero-badge">🌿 SUSTAINABLE FASHION</div>
    <h1>Welcome to <em>Nana Shop</em>,<br/>pre-loved fashion you'll love</h1>
    <p>Shop thousands of verified second-hand items — or sell what you no longer need. Good for your wallet, great for the planet.</p>
    <div class="hero-btns">
      <button class="btn-primary" onclick="showPage('shop')">Shop now</button>
      <button class="btn-outline" onclick="showPage('sell')">List an item</button>
    </div>
    <div class="stats">
      <div><div class="stat-num">12K+</div><div class="stat-lbl">Items listed</div></div>
      <div><div class="stat-num">4.8★</div><div class="stat-lbl">Avg rating</div></div>
      <div><div class="stat-num">80%</div><div class="stat-lbl">Less CO₂</div></div>
      <div><div class="stat-num">3K+</div><div class="stat-lbl">Happy buyers</div></div>
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">Browse by category</h2>
    <div class="cats">
      <button class="cat-chip" onclick="showPage('shop')">👕 Tops</button>
      <button class="cat-chip" onclick="showPage('shop')">👖 Bottoms</button>
